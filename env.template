# ────────────────────────────────────────────────────────────────────
# AntiVibe — Environment Variable Template
# Copy this file to your .env files and fill in real values.
#
# Dashboard (Next.js):
#   cp env.template apps/dashboard/.env.local
#
# Sandbox Service (Python):
#   cp env.template services/sandbox-svc/.env
# ────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────
# Create a Supabase project at https://supabase.com/dashboard
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Settings → API → service_role key (DO NOT expose to client-side code)
# Used by dashboard server actions, webhook handlers, and the sandbox service
# to bypass RLS for admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Alias for NEXT_PUBLIC_SUPABASE_URL, used by sandbox-svc (Python backend)
SUPABASE_URL=

# ── Fly.io ──────────────────────────────────────────────────────────
# Generate a Machine-scoped API token at https://fly.io/user/personal_access_tokens
# with at least "write" access to the antivibe-sandbox-svc app.
# DO NOT use your personal Fly user token — create a service account token
# with the minimum scope needed.
FLY_API_TOKEN=

# ── LLM Providers ───────────────────────────────────────────────────
# Anthropic — get from https://console.anthropic.com/settings/keys
# Used by Tier 1 (static analysis) for semantic code review.
ANTHROPIC_API_KEY=

# Together AI — get from https://api.together.ai/settings/api-keys
# Used by Tier 3 (fuzz agent) for token forging and route discovery.
TOGETHER_API_KEY=

# ── Stripe ──────────────────────────────────────────────────────────
# Stripe secret key — get from https://dashboard.stripe.com/apikeys
# Used by the dashboard webhook handler to verify events and manage subscriptions.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — get from Dashboard → Webhooks → Endpoint
# Used to verify that incoming webhooks actually came from Stripe.
STRIPE_WEBHOOK_SECRET=

# ── Encryption ──────────────────────────────────────────────────────
# 32-byte hex key for encrypting Proof-of-Concept captures in storage.
# Generate one:
#   openssl rand -hex 32
# Used by the sandbox service to encrypt poc-captures bucket contents.
POC_ENCRYPTION_KEY=
